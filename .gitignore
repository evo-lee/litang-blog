# ── Build output ──────────────────────────────────────────────
.next/
.open-next/
.wrangler/
out/

# ── Dependencies ───────────────────────────────────────────────
node_modules/

# ── Generated content (tracked as empty dirs via .gitkeep) ────
content/.generated/*
!content/.generated/.gitkeep

# ── Reports (artifacts, not source) ───────────────────────────
reports/ai/*
!reports/ai/.gitkeep
reports/build/*
!reports/build/.gitkeep

# ── Search index (regenerated every build) ────────────────────
public/search-index.json

# ── Environment variables ─────���────────────────────────────────
.env
.env.local
.env.*.local
# .env.example is intentionally NOT ignored — it is committed.

# ── OS & editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/

# ── Logs ───────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript incremental build info ─────────────────────────
*.tsbuildinfo
.gstack/
