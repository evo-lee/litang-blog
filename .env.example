# Environment Variables Template
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and must never be committed.
#
# 环境变量模板
# 复制此文件为 .env.local 并填入真实值。
# .env.local 已被 .gitignore 排除，绝不能提交到 Git。

# ── Analytics ─────────────────────────────────────────────────
# Umami — self-hosted privacy-friendly analytics
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Feature flags — set to "false" to disable independently
NEXT_PUBLIC_ENABLE_UMAMI=true
NEXT_PUBLIC_ENABLE_GA=true

# ── Typography ────────────────────────────────────────────────
# Heti Chinese typography enhancement (Phase 6)
NEXT_PUBLIC_ENABLE_HETI=true

# ── Cloudflare (server-side / CI only, never NEXT_PUBLIC_) ───
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# ── AI Tooling (server-side / CI only) ───────────────────────
# Choose one provider: anthropic or openai
AI_PROVIDER=anthropic

# Anthropic mode
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI mode
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
