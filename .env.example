# ============================================================
# ⚠️  TEMPLATE ONLY — DO NOT FILL REAL VALUES HERE  ⚠️
# ⚠️  仅为模板 — 此文件禁止填写真实密钥  ⚠️
# ============================================================
#
# Workflow / 使用方法:
#   1. Copy this file: `cp .env.example .env.local`
#   2. Edit .env.local (gitignored) with real values
#   3. NEVER edit .env.example with real values
#   4. NEVER commit .env.local
#
# Production secrets belong in the Cloudflare Workers dashboard,
# NOT in this repository. See docs/deploy/cloudflare.md.
#
# 生产环境密钥应配置在 Cloudflare Workers 控制台，
# 而非本仓库。详见 docs/deploy/cloudflare.md。

# ── Analytics ─────────────────────────────────────────────────
# Umami — self-hosted privacy-friendly analytics
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature flags — set to "false" to disable independently
NEXT_PUBLIC_ENABLE_UMAMI=true
NEXT_PUBLIC_ENABLE_GA=true

# ── Typography ────────────────────────────────────────────────
# Heti Chinese typography enhancement (Phase 6)
NEXT_PUBLIC_ENABLE_HETI=true

# ── Cloudflare (server-side / CI only, never NEXT_PUBLIC_) ───
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# ── AI Tooling (server-side / CI only) ───────────────────────
# Choose one provider: anthropic or openai
AI_PROVIDER=openai

# Anthropic mode
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI mode
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
