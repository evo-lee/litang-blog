# Environment Variables Template
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and must never be committed.
#
# 环境变量模板
# 复制此文件为 .env.local 并填入真实值。
# .env.local 已被 .gitignore 排除，绝不能提交到 Git。

# ── Analytics ─────────────────────────────────────────────────
# Umami — self-hosted privacy-friendly analytics
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature flags — set to "false" to disable independently
NEXT_PUBLIC_ENABLE_UMAMI=true
NEXT_PUBLIC_ENABLE_GA=true

# ── Typography ────────────────────────────────────────────────
# Heti Chinese typography enhancement (Phase 6)
NEXT_PUBLIC_ENABLE_HETI=true

# ── Cloudflare (server-side / CI only, never NEXT_PUBLIC_) ───
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# ── AI Tooling (server-side / CI only) ───────────────────────
# Choose one provider: anthropic or openai
AI_PROVIDER=openai

# Anthropic mode
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI mode
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
